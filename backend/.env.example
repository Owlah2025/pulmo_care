# ─────────────────────────────────────────────────────────────
# PULMO CARE — Backend Environment Variables
# Copy to .env and fill in real values before running
# NEVER commit the real .env to source control
# ─────────────────────────────────────────────────────────────

# PostgreSQL / TimescaleDB
POSTGRES_USER=pulmo_user
POSTGRES_PASSWORD=pulmo_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pulmo_care

# JWT Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production_use_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI (for PULMO AI Chatbot)
# Leave blank to use the rule-based fallback
OPENAI_API_KEY=

# AWS (for Cognito, S3, CloudWatch)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
